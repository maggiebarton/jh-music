{
  "name": "joshua-t-hester-music",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build:tailwind": "tailwindcss -c ./tailwind.config.cjs -i ./tailwind.input.css -o ./tailwind.generated.css --minify",
    "build": "npm run build:tailwind && node ./scripts/prepare-static.mjs",
    "preview": "python3 -m http.server 8000 --directory docs",
    "watch:tailwind": "tailwindcss -c ./tailwind.config.cjs -i ./tailwind.input.css -o ./tailwind.generated.css --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "sharp": "0.35.3",
    "tailwindcss": "3.4.17"
  },
  "type": "module"
}
