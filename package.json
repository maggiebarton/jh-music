{
  "name": "joshua-t-hester-music",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build:tailwind": "tailwindcss -c ./tailwind.config.cjs -i ./tailwind.input.css -o ./tailwind.generated.css --minify",
    "prepare:static": "node ./scripts/prepare-static.mjs",
    "build": "npm run build:tailwind && npm run prepare:static && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "dev": "npm run build:tailwind && npm run prepare:static && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "watch:tailwind": "tailwindcss -c ./tailwind.config.cjs -i ./tailwind.input.css -o ./tailwind.generated.css --watch"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "react-server-dom-webpack": "19.2.6",
    "sharp": "0.35.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
